rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParticipant(conversationData) {
      return isAuthenticated() &&
        (request.auth.uid in conversationData.participants ||
         (conversationData.participantIds != null && request.auth.uid in conversationData.participantIds));
    }

    function isGroupAdmin(admins) {
      return isAuthenticated() && admins != null && request.auth.uid in admins;
    }

    // ============================================================
    // USERS COLLECTION
    // ============================================================
    match /users/{userId} {
      allow read: if isAuthenticated() ||
                     (resource != null && (
                       'activeDeviceToken' in resource.data ||
                       'forceLogout' in resource.data ||
                       'deviceInfo' in resource.data
                     ));

      allow create: if isOwner(userId);

      // Owner can update anything, OR:
      // - Anyone can update device fields (single-device logout)
      // - Other auth users can update connection fields (batch from connection_service)
      // - Reviewers can update rating fields (from review_service)
      allow update: if isOwner(userId) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                         'activeDeviceToken', 'deviceName', 'deviceInfo',
                         'forceLogout', 'lastSessionUpdate'
                       ])) ||
                       (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                         'connections', 'connectionCount'
                       ])) ||
                       (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                         'averageRating', 'totalReviews'
                       ]));

      allow delete: if isOwner(userId);

      // Saved posts subcollection: users/{uid}/saved_posts/{postId}
      // Fields: postId, postData (map), savedAt
      match /saved_posts/{postId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // Hidden conversations subcollection: users/{uid}/hiddenConversations/{conversationId}
      match /hiddenConversations/{conversationId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // Blocked users subcollection: users/{uid}/blocked_users/{blockedUserId}
      // Fields: blockedUserId, blockedUserName, blockedUserPhoto, blockedAt
      match /blocked_users/{blockedUserId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // Blocked subcollection (alternative structure)
      match /blocked/{blockedUserId} {
        allow read, write: if isOwner(userId);
      }

      // Private data subcollection
      match /private/{document=**} {
        allow read, write: if isOwner(userId);
      }

      // Security events subcollection (immutable logs)
      match /securityEvents/{eventId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // Cleared chats subcollection
      match /clearedChats/{conversationId} {
        allow read, write: if isOwner(userId);
      }

      // Activity log subcollection (immutable)
      match /activity/{activityId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // ============================================================
    // POSTS COLLECTION
    // Fields: userId, originalPrompt, title, description, isActive,
    //   allowCalls, isDonation, currency, hashtags, imageUrl, images,
    //   price, viewCount, matchedUserIds, createdAt, updatedAt, deletedAt
    // ============================================================
    match /posts/{postId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      // Owner can update anything, OR any auth user can update viewCount/matchedUserIds
      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'viewCount', 'matchedUserIds'
         ]));

      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAuthenticated() &&
          resource.data.userId == request.auth.uid;
      }

      match /likes/{likeId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && likeId == request.auth.uid;
      }
    }

    // ============================================================
    // CONVERSATIONS COLLECTION (DMs & Groups)
    // Fields: participants[], participantNames, participantPhotos,
    //   isGroup, groupName, groupPhoto, admins, createdBy,
    //   lastMessage, lastMessageTime, lastMessageSenderId,
    //   unreadCount, isTyping, isMuted, chatTheme, metadata
    // ============================================================
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() &&
        (resource == null ||
         request.auth.uid in resource.data.participants ||
         (resource.data.participantIds != null && request.auth.uid in resource.data.participantIds));

      allow create: if isAuthenticated() &&
        (request.auth.uid in request.resource.data.participants ||
         (request.resource.data.participantIds != null && request.auth.uid in request.resource.data.participantIds));

      allow update: if isAuthenticated() &&
        (request.auth.uid in resource.data.participants ||
         (resource.data.participantIds != null && request.auth.uid in resource.data.participantIds));

      allow delete: if isAuthenticated() &&
        (request.auth.uid in resource.data.participants ||
         (resource.data.participantIds != null && request.auth.uid in resource.data.participantIds) ||
         (resource.data.isGroup == true && isGroupAdmin(resource.data.admins)));

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)).data);

        allow create: if isAuthenticated() &&
          isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)).data);

        allow update: if isAuthenticated() &&
          isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)).data);

        allow delete: if isAuthenticated() &&
          isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)).data);
      }
    }

    // ============================================================
    // CALLS COLLECTION (Voice Calls)
    // Fields: callerId, receiverId, callerName, callerPhoto,
    //   receiverName, receiverPhoto, participants[], status, type,
    //   source, timestamp, createdAt, offer, answer
    // ============================================================
    match /calls/{callId} {
      // Both caller and receiver can read (supports both field check and participants array query)
      allow read: if isAuthenticated() &&
        (resource.data.callerId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid ||
         request.auth.uid in resource.data.participants);

      // Caller creates the call doc
      allow create: if isAuthenticated() &&
        request.resource.data.callerId == request.auth.uid;

      // Both caller and receiver can update (status, SDP, stale cleanup)
      allow update: if isAuthenticated() &&
        (resource.data.callerId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);

      // Either party can delete call doc (cleanup after call ends)
      allow delete: if isAuthenticated() &&
        (resource.data.callerId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);

      // WebRTC ICE candidates
      match /callerCandidates/{candidateId} {
        allow read, write: if isAuthenticated() &&
          (get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid ||
           get(/databases/$(database)/documents/calls/$(callId)).data.receiverId == request.auth.uid);
      }

      match /receiverCandidates/{candidateId} {
        allow read, write: if isAuthenticated() &&
          (get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid ||
           get(/databases/$(database)/documents/calls/$(callId)).data.receiverId == request.auth.uid);
      }

      // Fallback signaling patterns
      match /signaling/{signalingId} {
        allow read, write: if isAuthenticated() &&
          (get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid ||
           get(/databases/$(database)/documents/calls/$(callId)).data.receiverId == request.auth.uid);
      }

      match /ice_candidates/{candidateId} {
        allow read, write: if isAuthenticated() &&
          (get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid ||
           get(/databases/$(database)/documents/calls/$(callId)).data.receiverId == request.auth.uid);
      }
    }

    // ============================================================
    // GROUP CALLS COLLECTION
    // Note: Some code uses callerId, some uses callerUserId
    // ============================================================
    match /group_calls/{callId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();

      match /participants/{participantId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }

      match /signaling/{document=**} {
        allow read, write: if isAuthenticated();
      }

      match /ice_candidates/{document=**} {
        allow read, write: if isAuthenticated();
      }
    }

    // ============================================================
    // CONNECTION REQUESTS COLLECTION
    // Fields: senderId, senderName, senderPhoto, senderAge, senderOccupation,
    //   senderLatitude, senderLongitude, receiverId, receiverName, receiverPhoto,
    //   receiverAge, receiverOccupation, receiverLatitude, receiverLongitude,
    //   message, status, createdAt, updatedAt
    // ============================================================
    match /connection_requests/{requestId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.senderId != request.resource.data.receiverId;

      allow update: if isAuthenticated() &&
        (resource.data.receiverId == request.auth.uid ||
         resource.data.senderId == request.auth.uid);

      allow delete: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);
    }

    // ============================================================
    // NOTIFICATIONS COLLECTION (Flat, cross-user writes)
    // Fields: userId (target), senderId, title, body, type, data, read, createdAt
    // ============================================================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated();

      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ============================================================
    // MATCHES COLLECTION
    // ============================================================
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ============================================================
    // BUSINESSES COLLECTION
    // Owner field: userId (NOT ownerId)
    // Non-owner updates: followerCount, viewCount, rating, reviewCount, order counters
    // ============================================================
    match /businesses/{businessId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'followerCount', 'viewCount', 'rating', 'reviewCount',
           'totalOrders', 'todayOrders', 'pendingOrders',
           'completedOrders', 'cancelledOrders',
           'totalEarnings', 'monthlyEarnings', 'todayEarnings'
         ]));

      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      // All business subcollections:
      // product_categories, products, menu_categories, menu_items,
      // rooms, food_orders, room_bookings, reviews, activity, orders,
      // bookings, appointments, inquiries, services, classes,
      // member_checkins, meetings, attendance, artworks, commissions
      match /{subcollection}/{docId} {
        allow read: if isAuthenticated();
        // Owner manages, customers can create orders/bookings/reviews
        allow create, update, delete: if isAuthenticated();
      }
    }

    // ============================================================
    // BUSINESS LISTINGS COLLECTION
    // ============================================================
    match /business_listings/{listingId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    // ============================================================
    // BUSINESS REVIEWS COLLECTION (Flat, old approach)
    // Reviewer field: userId (NOT reviewerId)
    // ============================================================
    match /business_reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ============================================================
    // BUSINESS FOLLOWERS COLLECTION
    // Field: userId (NOT followerId)
    // ============================================================
    match /business_followers/{followId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ============================================================
    // BUSINESS ORDERS COLLECTION (Customers create, both sides update)
    // ============================================================
    match /business_orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ============================================================
    // BUSINESS POSTS COLLECTION
    // ============================================================
    match /business_posts/{postId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    // ============================================================
    // PROFESSIONAL SERVICES COLLECTION
    // Non-owner can increment inquiries count
    // ============================================================
    match /services/{serviceId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'inquiries'
         ]));

      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ============================================================
    // PORTFOLIO COLLECTION
    // ============================================================
    match /portfolio/{portfolioId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ============================================================
    // PROFESSIONAL STATS COLLECTION
    // Updated by clients (inquiries) and reviewers
    // ============================================================
    match /professional_stats/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ============================================================
    // INQUIRIES COLLECTION (Client creates, professional responds)
    // Fields: clientId, professionalId, serviceId, message, status
    // ============================================================
    match /inquiries/{inquiryId} {
      allow read: if isAuthenticated() &&
        (resource.data.clientId == request.auth.uid ||
         resource.data.professionalId == request.auth.uid);

      allow create: if isAuthenticated() &&
        request.resource.data.clientId == request.auth.uid;

      allow update: if isAuthenticated() &&
        (resource.data.clientId == request.auth.uid ||
         resource.data.professionalId == request.auth.uid);

      allow delete: if isAuthenticated() &&
        (resource.data.clientId == request.auth.uid ||
         resource.data.professionalId == request.auth.uid);
    }

    // ============================================================
    // REVIEWS COLLECTION (Professional reviews)
    // Fields: reviewerId, professionalId, rating, reviewText
    // ============================================================
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.reviewerId == request.auth.uid;

      allow update: if isAuthenticated() &&
        (resource.data.reviewerId == request.auth.uid ||
         resource.data.professionalId == request.auth.uid);

      allow delete: if isAuthenticated() &&
        resource.data.reviewerId == request.auth.uid;
    }

    // ============================================================
    // REVIEW FLAGS COLLECTION (Immutable)
    // ============================================================
    match /review_flags/{flagId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================================
    // REPORTED REVIEWS COLLECTION (Immutable)
    // Fields: reviewId, businessId, reportedBy, reason, createdAt
    // ============================================================
    match /reported_reviews/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================================
    // ORDERS COLLECTION (Customer orders)
    // Fields: userId (buyer), orderId, itemName, status, totalAmount
    // ============================================================
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow delete: if false;
    }

    // ============================================================
    // FOOD ORDERS COLLECTION (Top-level, status updates)
    // ============================================================
    match /food_orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ============================================================
    // ROOM BOOKINGS COLLECTION (Top-level, status updates)
    // ============================================================
    match /room_bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ============================================================
    // NETWORKING PROFILES COLLECTION
    // Doc ID = user's UID, field: userId
    // ============================================================
    match /networking_profiles/{profileId} {
      allow read: if isAuthenticated();

      // Owner can create their own profile (profileId == uid),
      // OR any auth user can create a doc with only connection fields
      allow create: if isAuthenticated() &&
        (profileId == request.auth.uid ||
         request.resource.data.userId == request.auth.uid ||
         request.resource.data.keys().hasOnly(['connections', 'connectionCount']));

      // Owner can update anything, OR any auth user can update connection fields
      allow update: if isAuthenticated() &&
        (profileId == request.auth.uid ||
         resource.data.userId == request.auth.uid ||
         request.resource.data.userId == request.auth.uid ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'connections', 'connectionCount'
         ]));

      allow delete: if isAuthenticated() &&
        (profileId == request.auth.uid ||
         resource.data.userId == request.auth.uid);

      // Multiple profiles subcollection
      match /profiles/{subProfileId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && profileId == request.auth.uid;
        allow update, delete: if isAuthenticated() && profileId == request.auth.uid;
      }
    }

    // ============================================================
    // BLOCKS COLLECTION
    // ============================================================
    match /blocks/{blockId} {
      allow read: if isAuthenticated() &&
        resource.data.blockerId == request.auth.uid;

      allow create: if isAuthenticated() &&
        request.resource.data.blockerId == request.auth.uid;

      allow delete: if isAuthenticated() &&
        resource.data.blockerId == request.auth.uid;

      match /blocked_users/{blockedId} {
        allow read, write: if isAuthenticated() &&
          blockId == request.auth.uid;
      }
    }

    // ============================================================
    // REPORTS COLLECTION (Immutable)
    // ============================================================
    match /reports/{reportId} {
      allow read: if isAuthenticated() &&
        resource.data.reporterId == request.auth.uid;

      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;

      allow update, delete: if false;
    }

    // ============================================================
    // FEEDBACK COLLECTION (Immutable)
    // ============================================================
    match /feedback/{feedbackId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow update, delete: if false;
    }

    // ============================================================
    // INTENT CLARIFICATIONS COLLECTION (Immutable logs)
    // ============================================================
    match /intent_clarifications/{clarificationId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow update, delete: if false;
    }

    // ============================================================
    // CHAT HISTORY COLLECTION
    // ============================================================
    match /chat_history/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ============================================================
    // PROJECTS COLLECTION
    // ============================================================
    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ============================================================
    // USER STATUS/PRESENCE
    // ============================================================
    match /status/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // ============================================================
    // SEARCH INDEX (Server-side only)
    // ============================================================
    match /search_index/{document=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================================
    // GLOBAL CONFIG (Read-only)
    // ============================================================
    match /config/{document=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================================
    // DEPRECATED COLLECTIONS (Read-only for migration)
    // ============================================================
    match /intents/{intentId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /user_intents/{intentId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /processed_intents/{intentId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /embeddings/{embeddingId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================================
    // TEMP COLLECTION
    // ============================================================
    match /temp/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ============================================================
    // LISTING IMAGES (cache for nearby/feed cards)
    // ============================================================
    match /listing_images/{listingId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
    }
  }
}
